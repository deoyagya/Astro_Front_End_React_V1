# Vedic Astro Frontend — Environment Variables
# Copy to .env and fill in values

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# Stripe publishable key (for Embedded Checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Razorpay publishable key (legacy, no longer used)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Social login
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_APP_ID=

# Optional client-side site gate
VITE_SITE_GATE_CODE=
